# =============================================================================
# CommitFlow Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit the actual .env file to version control.

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Local:      mongodb://localhost:27017/commitflow
# Production: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/commitflow
MONGO_URI=mongodb://localhost:27017/commitflow

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Generate a strong, random secret (e.g. openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_long_random_secret_string_minimum_32_characters
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Development: http://localhost:5173 (Vite default)
# Production:  https://your-production-domain.com
CORS_ORIGIN=http://localhost:5173
